# ----------------------------------------------------------------------------
# Fortuno — Production secrets (template)
# Copie este arquivo para .env.prod e preencha com valores reais antes do
# deploy. Todas as entradas abaixo devem existir como GitHub Secrets do
# repositório para o pipeline .github/workflows/deploy-prod.yml.
#
# O Postgres NÃO sobe via docker-compose-prod.yml — o DB é externo, então
# precisamos apenas da connection string de cada tenant. Usuário, senha,
# database, host, etc. vivem embutidos dentro da própria connection string.
#
# Valores não-secretos (BaseURLs, tenant fixo "fortuna", bucket, S3 region,
# CORS=false) vivem em appsettings.Production.json — NÃO duplicar aqui.
# ----------------------------------------------------------------------------

# Database — connection string do tenant "fortuna"
CONNECTION_STRING=Host=<DB_HOST>;Port=5432;Database=fortuno_prod;Username=fortuno_prod;Password=<STRONG_POSTGRES_PASSWORD>

# NAuth — JWT secret compartilhado para validar tokens do tenant "fortuna"
NAUTH_JWT_SECRET=<NAUTH_JWT_SECRET_MIN_64_CHARS>

# ProxyPay — HMAC compartilhado dos webhooks ProxyPay → Fortuno
PROXYPAY_WEBHOOK_SECRET=<HMAC_SECRET_MIN_64_CHARS>
