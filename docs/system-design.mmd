%% Diagram: Fortuno — System Design
%% Type: Flowchart
%% Generated: 2026-04-27

flowchart LR
    %% ─────────── Actors ───────────
    subgraph Actors["Actors"]
        Owner["Lottery Owner / Admin"]
        Player["Player / Buyer"]
    end

    %% ─────────── Fortuno.API process ───────────
    subgraph FortunoAPI["Fortuno.API (.NET 8)"]
        direction TB
        REST["REST Controllers<br/>(LotteriesController, TicketsController, ...)"]
        GQL["GraphQL Endpoint<br/>(HotChocolate /graphql)"]
        Middleware["EnsureUserReferrer<br/>Middleware"]
        AppDI["Application — DI / Startup<br/>(Fortuno.Application)"]
        DomainSvc["Domain Services<br/>(Fortuno.Domain.Services)"]
        EF["EF Core 9 — FortunoContext<br/>(Fortuno.Infra)"]
    end

    %% ─────────── External systems ───────────
    subgraph External["External Systems"]
        direction TB
        PG[("PostgreSQL 17<br/>db: fortuno<br/>tables: fortuna_*")]
        NAuth["NAuth<br/>Basic auth + users"]
        ProxyPay["ProxyPay<br/>Stores + PIX payments"]
        ZTools["zTools<br/>S3 upload + email + slug"]
        S3[("AWS S3<br/>fortuno bucket")]
        Mail["MailerSend"]
    end

    %% ─────────── Edges ───────────
    Owner -- "HTTPS REST + Authorization Basic" --> REST
    Owner -- "GraphQL Query" --> GQL
    Player -- "HTTPS REST + Authorization Basic" --> REST
    Player -- "GraphQL Query" --> GQL

    REST --> Middleware
    GQL --> Middleware
    Middleware --> AppDI
    AppDI --> DomainSvc
    DomainSvc --> EF
    EF -- "EF Core / Npgsql" --> PG

    DomainSvc -- "Validate token + GetUser" --> NAuth
    DomainSvc -- "GetStore + Create PIX charge" --> ProxyPay
    DomainSvc -- "Upload image / Send email / Build slug" --> ZTools
    ZTools -- "S3 upload" --> S3
    ZTools -- "Send email" --> Mail

    ProxyPay -- "PIX webhook" --> REST
    REST -. "writes fortuna_ticket_orders" .-> EF

    %% ─────────── Styling ───────────
    classDef actor fill:#fef3c7,stroke:#b45309,color:#78350f;
    classDef api fill:#dbeafe,stroke:#1d4ed8,color:#1e3a8a;
    classDef ext fill:#dcfce7,stroke:#15803d,color:#14532d;
    classDef store fill:#f3e8ff,stroke:#7e22ce,color:#581c87;

    class Owner,Player actor;
    class REST,GQL,Middleware,AppDI,DomainSvc,EF api;
    class NAuth,ProxyPay,ZTools,Mail ext;
    class PG,S3 store;
