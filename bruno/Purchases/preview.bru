meta {
  name: Preview Purchase (public)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/purchases/preview
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "lotteryId": {{lotteryId}},
    "quantity": 5,
    "mode": "Random",
    "pickedNumbers": null,
    "referralCode": null
  }
}
