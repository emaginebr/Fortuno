meta {
  name: Update Lottery Combo
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/api/lottery-combos/{{lotteryComboId}}
  body: json
  auth: none
}

headers {
  Authorization: Basic {{accessToken}}
  Content-Type: application/json
}

body:json {
  {
    "lotteryId": {{lotteryId}},
    "name": "5 Tickets Combo (updated)",
    "discountValue": 15.0,
    "discountLabel": "15% OFF",
    "quantityStart": 5,
    "quantityEnd": 9
  }
}
