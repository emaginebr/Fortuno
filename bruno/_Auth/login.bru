meta {
  name: Login (NAuth)
  type: http
  seq: 1
}

post {
  url: {{nauthUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "tenant":   "{{nauthTenant}}",
    "user":     "{{nauthUser}}",
    "password": "{{nauthPassword}}"
  }
}

script:post-response {
  if (res.status >= 200 && res.status < 300 && res.body && res.body.token) {
    bru.setVar("accessToken", res.body.token);
  }
}
