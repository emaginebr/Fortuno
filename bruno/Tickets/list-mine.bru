meta {
  name: List My Tickets
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/tickets/mine?lotteryId={{lotteryId}}
  body: none
  auth: bearer
}

params:query {
  lotteryId: {{lotteryId}}
  ~number: 
  ~fromDate: 
  ~toDate: 
}

headers {
  X-Tenant-Id: fortuno
}

auth:bearer {
  token: {{token}}
}

vars:pre-request {
  lotteryId: 1
}
