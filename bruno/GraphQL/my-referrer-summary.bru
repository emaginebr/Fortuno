meta {
  name: My Referrer Summary (auth)
  type: graphql
  seq: 4
}

post {
  url: {{baseUrl}}/graphql
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:graphql {
  query MyReferrerSummary {
    myReferrerSummary {
      referralCode
      totalPurchases
      totalToReceive
      note
      byLottery {
        lotteryId
        lotteryName
        amount
        purchases
      }
    }
  }
}
