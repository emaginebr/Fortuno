meta {
  name: Update Raffle Award
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/api/raffle-awards/{{raffleAwardId}}
  body: json
  auth: none
}

headers {
  Authorization: Basic {{accessToken}}
  Content-Type: application/json
}

body:json {
  {
    "position": 1,
    "description": "R$ 12.000,00"
  }
}
