meta {
  name: Confirm Winners
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/raffles/{{raffleId}}/winners/confirm
  body: json
  auth: none
}

headers {
  Authorization: Basic {{accessToken}}
  Content-Type: application/json
}

body:json {
  {
    "raffleId": {{raffleId}},
    "winningNumbers": [1, 2, 3]
  }
}
