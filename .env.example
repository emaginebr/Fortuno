# ----------------------------------------------------------------------------
# Fortuno — Docker environment (template)
# Copie este arquivo para .env e preencha os valores antes de subir os
# containers. Placeholders: <...>.
# ----------------------------------------------------------------------------

# App
APP_PORT=5000
ASPNETCORE_ENVIRONMENT=Docker

# Database
POSTGRES_USER=fortuno
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_DB=fortuno
CONNECTION_STRING=Host=postgres;Port=5432;Database=fortuno;Username=fortuno;Password=<POSTGRES_PASSWORD>

# NAuth (microserviço externo, tenant "fortuna")
NAUTH_BASE_URL=http://nauth:80
NAUTH_TENANT=fortuna
NAUTH_API_KEY=<NAUTH_API_KEY>

# ProxyPay (microserviço externo, tenant "fortuna")
PROXYPAY_BASE_URL=http://proxypay:80
PROXYPAY_TENANT=fortuna
PROXYPAY_API_KEY=<PROXYPAY_API_KEY>
PROXYPAY_WEBHOOK_SECRET=<PROXYPAY_WEBHOOK_SECRET_min_32_chars>

# zTools (microserviço externo)
ZTOOLS_BASE_URL=http://ztools:80
ZTOOLS_API_KEY=<ZTOOLS_API_KEY>
ZTOOLS_S3_BUCKET_NAME=fortuno-docker
ZTOOLS_S3_REGION=us-east-1

# CORS
CORS_ALLOW_ANY_ORIGIN=false
