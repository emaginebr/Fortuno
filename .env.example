# ----------------------------------------------------------------------------
# Fortuno — Docker environment (template)
# Copie este arquivo para .env e preencha os valores antes de subir os
# containers. Placeholders: <...>.
# ----------------------------------------------------------------------------

# App
APP_PORT=5000
ASPNETCORE_ENVIRONMENT=Docker

# Database
POSTGRES_USER=fortuno
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_DB=fortuno
FORTUNO_CONNECTION_STRING=Host=postgres;Port=5432;Database=fortuno;Username=fortuno;Password=<POSTGRES_PASSWORD>

# NAuth (microserviço externo, tenant "fortuna")
NAUTH_API_URL=http://nauth-api:80
NAUTH_TENANT_ID=fortuna
FORTUNO_JWT_SECRET=<FORTUNO_JWT_SECRET_min_64_chars>
NAUTH_BUCKET_NAME=

# ProxyPay (microserviço externo, tenant "fortuno")
PROXYPAY_API_URL=http://proxypay-api:80
PROXYPAY_TENANT_ID=fortuno

# zTools (microserviço externo)
ZTOOLS_API_URL=http://ztools-api:8080
ZTOOLS_S3_BUCKET_NAME=fortuno-docker

# CORS
CORS_ALLOW_ANY_ORIGIN=false
